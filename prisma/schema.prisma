// Postgres holds only user/stateful data. The content graph (tracks, modules,
// lessons, exercises, assessments) is code-defined and referenced here by
// string IDs.

generator client {
  provider = "prisma-client-js"
  // Driver adapters: on Cloudflare Workers the client runs through
  // @prisma/adapter-pg over the Hyperdrive binding (see src/lib/db.ts). Keep
  // the default output dir — @opennextjs/cloudflare patches the generated
  // client at build and can't if output is customized.
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  // PlanetScale for Postgres. In prod the connection comes from the Hyperdrive
  // binding, not this env var. DATABASE_URL is for local dev only: the *pooled*
  // string (PgBouncer, port 6432) in .env. Schema migrations live in
  // db/migrations and are applied manually with psql against the *direct* port
  // (5432, admin role) — never by `prisma migrate` against prod.
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  workosUserId String   @unique
  email        String
  name         String?
  imageUrl     String?
  createdAt    DateTime @default(now())

  lessonProgress    LessonProgress[]
  submissions       Submission[]
  memberships       ClassroomMembership[]
  createdClassrooms Classroom[]           @relation("ClassroomCreatedBy")
}

enum ProgressStatus {
  not_started
  in_progress
  completed
}

model LessonProgress {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId     String
  status       ProgressStatus @default(in_progress)
  completedAt  DateTime?
  lastViewedAt DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
}

enum SubmissionKind {
  exercise
  assessment
}

enum SubmissionStatus {
  draft
  submitted
  graded
}

model Submission {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentId    String
  kind         SubmissionKind
  format       String?
  // closed-ended answers (selected option ids) or sectioned writing values
  responseJson Json?
  responseText String?
  status       SubmissionStatus @default(draft)
  score        Float?
  feedback     String?
  version      Int              @default(1)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([userId, contentId, kind])
  @@index([userId, contentId])
}

enum ClassroomRole {
  instructor
  student
}

model Classroom {
  id          String   @id @default(cuid())
  name        String
  joinCode    String   @unique
  trackId     String?
  createdById String
  createdBy   User     @relation("ClassroomCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  memberships ClassroomMembership[]
}

model ClassroomMembership {
  id          String        @id @default(cuid())
  classroomId String
  classroom   Classroom     @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        ClassroomRole @default(student)
  joinedAt    DateTime      @default(now())

  @@unique([classroomId, userId])
  @@index([userId])
}
