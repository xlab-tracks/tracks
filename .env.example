# Postgres = PlanetScale for Postgres. LOCAL DEV ONLY — production connects
# through the Cloudflare Hyperdrive binding instead (see wrangler.jsonc and
# src/lib/db.ts). Use the *pooled* connection string (PgBouncer, port 6432);
# the *direct* port (5432, admin role) is only for schema migrations and admin
# (psql). Schema migrations live in db/migrations and are applied manually —
# see CLAUDE.md.
DATABASE_URL="postgresql://user:password@host:6432/postgres?sslmode=verify-full"

# WorkOS AuthKit — create a project at https://dashboard.workos.com and enable
# Google as the only connection. Then fill these in.
WORKOS_API_KEY="sk_..."
WORKOS_CLIENT_ID="client_..."
# 32+ character random string: `openssl rand -base64 32`
WORKOS_COOKIE_PASSWORD="change_me_to_a_random_32_char_min_secret"
# Must match the redirect URI registered in the WorkOS dashboard.
NEXT_PUBLIC_WORKOS_REDIRECT_URI="http://localhost:3000/callback"

# Dev-only auth bypass (src/lib/auth.ts): resolves every request to a
# placeholder account so save/submit/grading work under `next dev` without
# real WorkOS credentials. 1 = default "Dev User"; an email gives a distinct
# account per address. Ignored outside NODE_ENV=development — but never
# expose a dev server running with this to the network.
# DEV_USER=1

# OpenRouter — reasoning-transparency grader (src/lib/grader). With the
# server key the model can be overridden per length class:
# OPENROUTER_MODEL_SHORT / _MEDIUM / _LONG, with OPENROUTER_MODEL as the
# shared fallback (default tencent/hy3:free). Signed-in users may store
# their own key, which takes precedence and grades on a paid default
# (moonshotai/kimi-k3; override with OPENROUTER_MODEL_USER). This exact
# placeholder value is treated as unset — grading stays hidden until a real
# key replaces it.
OPENROUTER_API_KEY="sk-or-..."
# Encrypts user-supplied grader API keys at rest (AES-GCM over
# UserApiKey.ciphertext — src/lib/grader/key-crypto.ts). 32+ random chars —
# enforced: shorter values and this exact placeholder are treated as unset.
# Rotating it orphans stored keys (the UI prompts users to re-add them).
# When unset, the add-your-own-key feature is hidden; the server-wide key
# still works.
API_KEY_ENCRYPTION_SECRET="change_me_to_a_random_32_char_min_secret"
