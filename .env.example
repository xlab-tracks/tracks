# Postgres connection string (Neon, Supabase Postgres, RDS, or local Docker).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/tracks?schema=public"

# WorkOS AuthKit — create a project at https://dashboard.workos.com and enable
# Google as the only connection. Then fill these in.
WORKOS_API_KEY="sk_..."
WORKOS_CLIENT_ID="client_..."
# 32+ character random string: `openssl rand -base64 32`
WORKOS_COOKIE_PASSWORD="change_me_to_a_random_32_char_min_secret"
# Must match the redirect URI registered in the WorkOS dashboard.
NEXT_PUBLIC_WORKOS_REDIRECT_URI="http://localhost:3000/callback"
